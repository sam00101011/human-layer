# Base URLs
APP_BASE_URL=https://<web-app-base-url>
API_BASE_URL=https://<api-base-url-or-web-app-base-url>

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Sessions and extension auth
SESSION_SECRET=<generate-a-long-random-secret>
EXTENSION_TOKEN_SECRET=<generate-a-long-random-secret>

# World ID
WORLD_ID_MODE=remote
WORLD_ID_ENVIRONMENT=production
NEXT_PUBLIC_WORLD_ID_APP_ID=<world-id-app-id>
WORLD_ID_APP_ID=<world-id-app-id>
NEXT_PUBLIC_WORLD_ID_ACTION=human-layer-v1
WORLD_ID_ACTION=human-layer-v1
NEXT_PUBLIC_WORLD_ID_SIGNAL=human-layer-v1
WORLD_ID_SIGNAL=human-layer-v1
WORLD_ID_RP_ID=<world-id-rp-id>
WORLD_ID_RP_PRIVATE_KEY=<world-id-rp-private-key>
WORLD_ID_VERIFY_URL=<world-id-verify-url>

# Redis
REDIS_URL=redis://<user>:<password>@<host>:6379

# Object storage
S3_REGION=<region>
S3_BUCKET=<bucket-name>
AWS_ACCESS_KEY_ID=<access-key-id>
AWS_SECRET_ACCESS_KEY=<secret-access-key>
# S3_ENDPOINT=<only-set-for-non-aws-s3-compatible-storage>

# Observability
SENTRY_DSN=<server-sentry-dsn>
NEXT_PUBLIC_SENTRY_DSN=<browser-sentry-dsn>
NEXT_PUBLIC_POSTHOG_KEY=<posthog-project-key>
NEXT_PUBLIC_POSTHOG_HOST=https://<posthog-host>
NEXT_PUBLIC_SUPPORT_EMAIL=<support@example.com>

# Direct API-key research providers
EXA_API_KEY=<exa-api-key>
# EXA_API_URL=https://api.exa.ai/search
PERPLEXITY_API_KEY=<perplexity-api-key>
# PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=<anthropic-api-key>
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-opus-4-20250514

# Native x402 research wallet
# Fund this key on Base for StableEnrich, anybrowse, StableClaude, and twit.sh.
X402_EVM_PRIVATE_KEY=<0x-base-private-key>
X402_EVM_NETWORK=eip155:8453

# Native MPP / Tempo wallet
# Fund this key on Tempo for Parallel Search.
MPPX_PRIVATE_KEY=<0x-tempo-private-key>
# MPPX_RPC_URL=https://rpc.tempo.xyz
